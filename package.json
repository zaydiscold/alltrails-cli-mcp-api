{
  "name": "alltrails-cli-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @zaydiscold/alltrails-cli build && pnpm --filter @zaydiscold/alltrails-cli-mcp build",
    "test": "pnpm --filter @zaydiscold/alltrails-cli test",
    "typecheck": "pnpm --filter @zaydiscold/alltrails-cli typecheck && pnpm --filter @zaydiscold/alltrails-cli build && pnpm --filter @zaydiscold/alltrails-cli-mcp typecheck",
    "cli": "pnpm --filter @zaydiscold/alltrails-cli cli"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
